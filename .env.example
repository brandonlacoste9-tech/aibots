# xAI (OpenAI-compatible) endpoint used by the agent loop
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-1-fast-non-reasoning

# Finnhub news API (optional)
FINNHUB_API_KEY=

# Alpha Vantage (optional) — news fallback + GLOBAL_QUOTE
# Free tier is rate-limited (~5 calls/min). Prefer for news when Finnhub is empty.
ALPHA_VANTAGE_API_KEY=

# Massive.com (Polygon-compatible) — news + prev-close quote
# MASSIVE_BASE_URL=https://api.polygon.io
MASSIVE_API_KEY=

# RavenPack Bigdata.com (bd_v2_ keys) — company knowledge graph + optional news
# Requires: pip install bigdata-client
BIGDATA_API_KEY=

# Default journal location (optional; falls back to ./journal.jsonl)
AIBOTS_JOURNAL_PATH=journal.jsonl

# Desk API CORS (comma-separated). Defaults include Netlify + indie-trader.com
# CORS_ORIGINS=https://spiffy-tiramisu-613b09.netlify.app,https://indie-trader.com,http://localhost:8080
