# xAI (OpenAI-compatible) endpoint used by the agent loop
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-1-fast-non-reasoning

# Finnhub news API (optional; get_news degrades to source="none" without it)
FINNHUB_API_KEY=

# Default journal location (optional; falls back to ./journal.jsonl)
AIBOTS_JOURNAL_PATH=journal.jsonl
